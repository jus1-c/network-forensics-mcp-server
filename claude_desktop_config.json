{
  "mcpServers": {
    "network-forensics": {
      "command": "python",
      "args": [
        "-m",
        "mcp_network_forensics"
      ],
      "description": "MCP Server for Network Forensics using PyShark",
      "env": {
        "MCP_SERVER_NAME": "mcp-network-forensics",
        "MCP_MAX_FILE_SIZE": "10737418240",
        "MCP_MAX_PACKETS": "10000",
        "MCP_TIMEOUT": "300"
      }
    }
  }
}
